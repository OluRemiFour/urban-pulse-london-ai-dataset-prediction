# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=urban_pulse
COLLECTION_ZILLOW=zillow_properties
COLLECTION_BOROUGH=borough_metrics

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Urban Pulse API
API_VERSION=1.0.0
API_DESCRIPTION=Investment Intelligence Platform for London Housing Market

# Data Processing
DATA_PATH=./data
ZILLOW_DATA_PATH=./data/zillow_properties_listing.csv
BOROUGH_DATA_PATH=./data/urban_pulse_borough_metrics.csv

# Environment
DEBUG=false
LOG_LEVEL=INFO

# Projection Settings
PROJECTION_CRS=EPSG:27700
TARGET_CRS=EPSG:4326
